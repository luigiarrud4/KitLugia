<Page x:Class="KitLugia.GUI.Pages.ServicesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      Title="ServicesPage" d:DesignHeight="600" d:DesignWidth="800">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Gerenciador de Processos" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
            <TabControl.Resources>
                <!-- Estilo das Abas (Reutilizando o estilo limpo) -->
                <Style TargetType="TabItem">
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="Foreground" Value="#AAAAAA"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Padding" Value="15,10"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border Name="Border" Background="{TemplateBinding Background}" BorderBrush="#3E3E42" BorderThickness="0,0,0,2" Margin="0,0,5,0">
                                    <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" Margin="10,2"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="BorderBrush" Value="#007ACC" />
                                        <Setter TargetName="Border" Property="BorderThickness" Value="0,0,0,3" />
                                        <Setter Property="Foreground" Value="#007ACC" />
                                        <Setter Property="FontWeight" Value="Bold" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- ABA 1: INICIALIZAÇÃO -->
            <TabItem Header="Inicialização (Startup)">
                <Grid Margin="0,15,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Aplicativos que iniciam com o Windows" Foreground="#CCCCCC" VerticalAlignment="Center"/>
                        <Button Content="Recarregar" Click="BtnRefreshStartup_Click" Margin="15,0,0,0" Padding="10,2" Background="#3E3E42" Foreground="White" BorderThickness="0"/>
                    </StackPanel>

                    <!-- Tabela de Startup -->
                    <DataGrid x:Name="GridStartup" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" SelectionMode="Single"
                              Background="#252526" RowBackground="#252526" AlternatingRowBackground="#2D2D30" Foreground="White" BorderThickness="0" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nome" Binding="{Binding Name}" Width="200" IsReadOnly="True" FontWeight="SemiBold"/>
                            <DataGridTextColumn Header="Comando / Caminho" Binding="{Binding FullCommand}" Width="*" IsReadOnly="True" Foreground="#AAAAAA"/>
                            <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Ações -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button Content="Desabilitar / Habilitar" Click="BtnToggleStartup_Click" Padding="15,8" Background="#3E3E42" Foreground="White" BorderThickness="0" Margin="0,0,10,0"/>
                        <Button Content="Adicionar Novo..." Click="BtnAddStartup_Click" Padding="15,8" Background="#007ACC" Foreground="White" BorderThickness="0"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ABA 2: SERVIÇOS (Simplificada) -->
            <TabItem Header="Otimização de Serviços">
                <StackPanel Margin="0,20,0,0">
                    <TextBlock Text="Presets de Otimização" FontSize="16" Foreground="White" FontWeight="SemiBold" Margin="0,0,0,15"/>
                    <TextBlock Text="Selecione um perfil para aplicar configurações aos serviços do Windows." Foreground="#AAAAAA" Margin="0,0,0,20"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Card Seguro -->
                        <Border Grid.Column="0" Background="#2D2D30" CornerRadius="5" Padding="15" Margin="0,0,10,0" BorderThickness="1" BorderBrush="#3E3E42">
                            <StackPanel>
                                <TextBlock Text="🛡️ Otimização Segura" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                                <TextBlock Text="Desativa apenas serviços inúteis como Fax, RetailDemo e Spooler (se não usar impressora)." Foreground="#888888" TextWrapping="Wrap" Height="60"/>
                                <Button Content="Aplicar Seguro" Click="BtnSafeOpt_Click" Margin="0,10,0,0" Padding="10,5" Background="#3E3E42" Foreground="White" BorderThickness="0"/>
                            </StackPanel>
                        </Border>

                        <!-- Card Gamer -->
                        <Border Grid.Column="1" Background="#2D2D30" CornerRadius="5" Padding="15" Margin="5,0,5,0" BorderThickness="1" BorderBrush="#007ACC">
                            <StackPanel>
                                <TextBlock Text="🎮 Otimização Gamer" Foreground="#007ACC" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                                <TextBlock Text="Desativa Telemetria, Mapas, Geo-localização e outros recursos que consomem RAM e CPU." Foreground="#888888" TextWrapping="Wrap" Height="60"/>
                                <Button Content="Aplicar Gamer" Click="BtnGamerOpt_Click" Margin="0,10,0,0" Padding="10,5" Background="#007ACC" Foreground="White" BorderThickness="0"/>
                            </StackPanel>
                        </Border>

                        <!-- Card Restaurar -->
                        <Border Grid.Column="2" Background="#2D2D30" CornerRadius="5" Padding="15" Margin="10,0,0,0" BorderThickness="1" BorderBrush="#3E3E42">
                            <StackPanel>
                                <TextBlock Text="⏪ Restaurar Padrões" Foreground="White" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                                <TextBlock Text="Reverte todos os serviços para o padrão de fábrica do Windows. Use se algo parar de funcionar." Foreground="#888888" TextWrapping="Wrap" Height="60"/>
                                <Button Content="Restaurar Tudo" Click="BtnRestoreServices_Click" Margin="0,10,0,0" Padding="10,5" Background="#3E3E42" Foreground="White" BorderThickness="0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </TabItem>

        </TabControl>
    </Grid>
</Page>