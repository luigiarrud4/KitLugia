<Page x:Class="KitLugia.GUI.Pages.ToolsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      Title="ToolsPage" d:DesignHeight="600" d:DesignWidth="800">

    <Page.Resources>
        <!-- Estilo simples para os botões das ferramentas -->
        <Style TargetType="Button" x:Key="ToolBtn">
            <Setter Property="Background" Value="#2D2D30"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4" BorderThickness="1" BorderBrush="#3E3E42">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="10,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Ferramentas e Utilitários" Foreground="White" FontSize="24" FontWeight="Bold" Margin="0,0,0,20"/>

        <!-- ABAS DE NAVEGAÇÃO -->
        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
            <TabControl.Resources>
                <Style TargetType="TabItem">
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Padding" Value="15,10"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border Name="Border" Background="{TemplateBinding Background}" BorderBrush="#3E3E42" BorderThickness="0,0,0,2" Margin="0,0,5,0">
                                    <ContentPresenter x:Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center" ContentSource="Header" Margin="10,2"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Border" Property="BorderBrush" Value="#007ACC" />
                                        <Setter TargetName="Border" Property="BorderThickness" Value="0,0,0,3" />
                                        <Setter Property="Foreground" Value="#007ACC" />
                                        <Setter Property="FontWeight" Value="Bold" />
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="False">
                                        <Setter Property="Foreground" Value="#AAAAAA" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>

            <!-- ABA 1: ENERGIA -->
            <TabItem Header="Energia">
                <StackPanel Margin="0,20,0,0" Width="500" HorizontalAlignment="Left">
                    <TextBlock Text="Gerenciador de Planos de Energia" FontSize="16" Foreground="White" Margin="0,0,0,15" FontWeight="SemiBold"/>

                    <TextBlock Text="Plano Atual:" Foreground="#AAAAAA" Margin="0,0,0,5"/>
                    <TextBlock x:Name="TxtCurrentPlan" Text="Carregando..." Foreground="#00FF00" FontWeight="Bold" Margin="0,0,0,20"/>

                    <TextBlock Text="Selecionar Plano:" Foreground="#AAAAAA" Margin="0,0,0,5"/>
                    <ComboBox x:Name="CmbPowerPlans" Height="35" Margin="0,0,0,10" DisplayMemberPath="Name" SelectedValuePath="Guid"/>
                    <Button Content="Ativar Plano Selecionado" Click="BtnActivatePlan_Click" Style="{StaticResource ToolBtn}" Background="#007ACC"/>

                    <Separator Background="#3E3E42" Margin="0,15"/>

                    <TextBlock Text="Planos Especiais" Foreground="#AAAAAA" Margin="0,0,0,10"/>
                    <Button Content="Desbloquear 'Desempenho Máximo' (Ultimate)" Click="BtnUltimate_Click" Style="{StaticResource ToolBtn}"/>
                    <Button Content="Importar 'Bitsum Highest Performance'" Click="BtnBitsum_Click" Style="{StaticResource ToolBtn}"/>
                </StackPanel>
            </TabItem>

            <!-- ABA 2: REDE -->
            <TabItem Header="Rede (DNS)">
                <StackPanel Margin="0,20,0,0" Width="500" HorizontalAlignment="Left">
                    <TextBlock Text="Otimização de DNS" FontSize="16" Foreground="White" Margin="0,0,0,15" FontWeight="SemiBold"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="Cloudflare (1.1.1.1)" Click="BtnDnsCloudflare_Click" Style="{StaticResource ToolBtn}" Margin="0,0,5,10"/>
                        <Button Grid.Column="1" Content="Google (8.8.8.8)" Click="BtnDnsGoogle_Click" Style="{StaticResource ToolBtn}" Margin="5,0,0,10"/>
                    </Grid>

                    <Button Content="Restaurar Automático (DHCP)" Click="BtnDnsDhcp_Click" Style="{StaticResource ToolBtn}" Background="#3E3E42"/>

                    <Separator Background="#3E3E42" Margin="0,15"/>

                    <TextBlock Text="Reparo de Rede" FontSize="16" Foreground="White" Margin="0,0,0,15" FontWeight="SemiBold"/>
                    <Button Content="Limpar Cache DNS (FlushDNS)" Click="BtnFlushDns_Click" Style="{StaticResource ToolBtn}"/>
                    <Button Content="Resetar Pilha de Rede (TCP/IP Reset)" Click="BtnNetReset_Click" Style="{StaticResource ToolBtn}" Background="#C42B1C"/>
                </StackPanel>
            </TabItem>

            <!-- ABA 3: SISTEMA E LOJA -->
            <TabItem Header="Sistema &amp; Loja">
                <StackPanel Margin="0,20,0,0" Width="500" HorizontalAlignment="Left">
                    <TextBlock Text="Microsoft Store &amp; Xbox" FontSize="16" Foreground="White" Margin="0,0,0,15" FontWeight="SemiBold"/>
                    <Button Content="Resetar Cache da Loja (WSReset)" Click="BtnStoreReset_Click" Style="{StaticResource ToolBtn}"/>
                    <Button Content="Reparar Gaming Services" Click="BtnGamingServices_Click" Style="{StaticResource ToolBtn}"/>

                    <Separator Background="#3E3E42" Margin="0,15"/>

                    <TextBlock Text="Extras do Sistema" FontSize="16" Foreground="White" Margin="0,0,0,15" FontWeight="SemiBold"/>
                    <Button Content="Ativar Editor de Política de Grupo (GPEDIT) - Home" Click="BtnGpedit_Click" Style="{StaticResource ToolBtn}"/>
                    <Button Content="Ativar/Desativar 'God Mode' no Desktop" Click="BtnGodMode_Click" Style="{StaticResource ToolBtn}"/>
                    <Button Content="Backup de Drivers (Pasta)" Click="BtnDriverBackup_Click" Style="{StaticResource ToolBtn}" Background="#007ACC"/>
                </StackPanel>
            </TabItem>

        </TabControl>
    </Grid>
</Page>