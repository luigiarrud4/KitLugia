<Page x:Class="KitLugia.GUI.Pages.BloatwarePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Bloatware">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Removedor de Bloatware" FontSize="28" FontWeight="SemiBold" Foreground="White"/>
            <TextBlock Text="Aplicativos nativos do Windows. Verde = Disponível para Reinstalar." Foreground="#AAA" Margin="0,5,0,0"/>
        </StackPanel>

        <Border x:Name="LoadingPanel" Grid.Row="2" Panel.ZIndex="99" Background="#CC000000" Visibility="Visible" CornerRadius="8">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="⌛" FontSize="40" HorizontalAlignment="Center" Foreground="{StaticResource AccentColor}"/>
                <TextBlock Text="Analisando..." Foreground="White" FontSize="16" Margin="0,15,0,0"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="#181818" BorderBrush="#333" BorderThickness="1" CornerRadius="8">
            <ListView x:Name="AppsList" Background="Transparent" BorderThickness="0" Foreground="White" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Margin" Value="0,2"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <Border x:Name="bdr" Background="{TemplateBinding Background}" CornerRadius="4" Padding="10">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bdr" Property="Background" Value="#252525"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="40"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="140"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="📦" FontSize="20" VerticalAlignment="Center" Foreground="#555"/>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                                <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" FontSize="14" Foreground="White"/>
                                <TextBlock Text="{Binding PackageName}" FontSize="11" Foreground="#666" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>

                            <!-- BOTÃO DE AÇÃO DINÂMICO -->
                            <Button Grid.Column="2" Height="30" FontSize="11" Cursor="Hand" Click="BtnAction_Click" Tag="{Binding}">
                                <Button.Style>
                                    <Style TargetType="Button">
                                        <!-- Estilo Padrão (Para REMOVER - Vermelho) -->
                                        <Setter Property="Content" Value="REMOVER"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderBrush" Value="#C42B1C"/>
                                        <Setter Property="Foreground" Value="#FF6F61"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="Button">
                                                    <Border x:Name="bdr" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="4">
                                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                    </Border>
                                                    <ControlTemplate.Triggers>
                                                        <!-- Trigger de MouseOver Padrão -->
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter TargetName="bdr" Property="Background" Value="#C42B1C"/>
                                                            <Setter Property="Foreground" Value="White"/>
                                                        </Trigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>

                                        <!-- MUDANÇA: Se IsInstalled = FALSE (Não Instalado), vira botão de Reinstalar -->
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsInstalled}" Value="False">
                                                <Setter Property="Content" Value="REINSTALAR (LOJA)"/>
                                                <Setter Property="BorderBrush" Value="#107C41"/>
                                                <!-- Verde -->
                                                <Setter Property="Foreground" Value="#107C41"/>

                                                <!-- Template separado para o estado Hover verde -->
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="bdr" Background="Transparent" BorderBrush="#107C41" BorderThickness="1" CornerRadius="4">
                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="bdr" Property="Background" Value="#107C41"/>
                                                                    <Setter Property="Foreground" Value="White"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Atualizar Lista" Click="BtnRefresh_Click" Height="35" Width="120" 
                    Background="#333" Foreground="White" BorderThickness="0">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Page>