<Window x:Class="KitLugia.GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:KitLugia.GUI.Controls"
        mc:Ignorable="d"
        Title="Kit Lugia - Gold Edition" Height="750" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBackground}"
        ResizeMode="CanResizeWithGrip">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40" GlassFrameThickness="0" CornerRadius="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Border BorderBrush="{StaticResource AccentColor}" BorderThickness="1">
        <Grid>
            <!-- DIVISÃO VERTICAL: CONTEÚDO EM CIMA, CONSOLE EM BAIXO -->
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <!-- App Principal -->
                <RowDefinition Height="Auto"/>
                <!-- Console (Expansível) -->
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ========================================================= -->
            <!-- ÁREA DE BOTÕES SUPERIORES (Direita) -->
            <!-- ========================================================= -->
            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" 
                        WindowChrome.IsHitTestVisibleInChrome="True" Margin="0,1,1,0" Panel.ZIndex="9999">

                <!-- BOTÃO INTEGRIDADE (ESCUDO) -->
                <RadioButton x:Name="BtnSecurity" GroupName="Menu" Tag="🛡️Scan" Content="Integridade do Sistema" 
                             Style="{StaticResource NavButtonStyle}" Click="NavButton_Click"
                             ToolTip="Scanner de Segurança (Antigo Menu [S])"/>

                <!-- BOTÃO ATUALIZAÇÃO (REFRESH) -->
                <Button x:Name="BtnUpdate" Width="40" Height="32" Click="BtnUpdate_Click"
                        Background="Transparent" BorderThickness="0" Margin="0,0,0,0" Cursor="Hand"
                        ToolTip="Verificar Atualizações">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bdr" Background="{TemplateBinding Background}" CornerRadius="4">
                                <TextBlock x:Name="refreshIcon" Text="↻" Foreground="#2196F3" FontWeight="Bold" 
                                           HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform CenterX="9" CenterY="9"/>
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bdr" Property="Background" Value="#222196F3"/>
                                    <Setter TargetName="refreshIcon" Property="Foreground" Value="#FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- BOTÃO DO CONSOLE (>_) -->
                <Button x:Name="BtnConsole" Width="40" Height="32" Click="BtnConsole_Click"
                        Background="Transparent" BorderThickness="0" Margin="0,0,0,0" Cursor="Hand"
                        ToolTip="Abrir/Fechar Terminal">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bdr" Background="{TemplateBinding Background}" CornerRadius="4">
                                <TextBlock Text=">_" Foreground="#00FF00" FontWeight="Bold" FontFamily="Consolas" 
                                           HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bdr" Property="Background" Value="#2200FF00"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- BOTÃO DE NOTIFICAÇÕES (SINO + CONTADOR) -->
                <Button x:Name="BtnNotifications" Width="46" Height="32" Click="BtnNotifications_Click"
                        Background="Transparent" BorderThickness="0" Margin="0,0,5,0" Cursor="Hand"
                        ToolTip="Histórico de Notificações">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bdr" Background="{TemplateBinding Background}" CornerRadius="4">
                                <Grid>
                                    <TextBlock Text="🔔" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="14"/>

                                    <!-- BADGE (CONTADOR VERMELHO) -->
                                    <Border x:Name="Badge" Background="#FF4444" CornerRadius="7" MinWidth="14" Height="14" 
                                            HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,6,10,0"
                                            Visibility="Collapsed">
                                        <!-- Invisível por padrão -->
                                        <TextBlock x:Name="TxtBadgeCount" Text="0" Foreground="White" FontSize="9" FontWeight="Bold" 
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" Padding="2,0"/>
                                    </Border>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bdr" Property="Background" Value="#22FFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- BOTÕES DE JANELA -->
                <Button Content="−" Width="46" Height="32" Foreground="White" Background="Transparent" 
                        BorderThickness="0" Click="BtnMinimize_Click" Style="{StaticResource {x:Type Button}}"/>
                <Button Content="□" Width="46" Height="32" Foreground="White" Background="Transparent" 
                        BorderThickness="0" Click="BtnMaximize_Click" Style="{StaticResource {x:Type Button}}"/>
                <Button Content="✕" Width="46" Height="32" Foreground="White" Background="Transparent" 
                        BorderThickness="0" Click="BtnClose_Click">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#C42B1C"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <!-- ========================================================= -->
            <!-- MENU LATERAL (ESQUERDA) -->
            <!-- ========================================================= -->
            <Border Grid.Row="0" Grid.Column="0" Background="{StaticResource SidebarBackground}" 
                    BorderThickness="0,0,1,0" BorderBrush="{StaticResource CardBorder}">
                <Grid Margin="15,25">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="KIT LUGIA" FontSize="18" FontWeight="Bold" Margin="5,0,0,5" Foreground="{StaticResource AccentColor}">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#FFD700" BlurRadius="12" ShadowDepth="0" Opacity="0.5"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        <TextBlock Text="U L T I M A T E   P E R F O R M A N C E" FontSize="10" Margin="5,0,0,20" Foreground="#808080" FontWeight="SemiBold"/>

                        <!-- BARRA DE PESQUISA -->
                        <Grid Margin="0,0,0,15">
                            <Border Background="#20FFFFFF" CornerRadius="6" Height="34" BorderBrush="{StaticResource CardBorder}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="🔍" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="12" Foreground="{StaticResource TextSecondary}"/>

                                    <TextBlock Text="Procurar tweak..." Grid.Column="1" VerticalAlignment="Center" Foreground="{StaticResource TextMuted}" 
                                               FontSize="12" FontStyle="Italic" IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=TxtGlobalSearch}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <TextBox x:Name="TxtGlobalSearch" Grid.Column="1" Background="Transparent" BorderThickness="0" 
                                             Foreground="White" VerticalAlignment="Center" FontSize="13" 
                                             CaretBrush="{StaticResource AccentColor}"
                                             TextChanged="TxtGlobalSearch_TextChanged"/>
                                </Grid>
                            </Border>

                            <Popup x:Name="SearchPopup" PlacementTarget="{Binding ElementName=TxtGlobalSearch}" 
                                   StaysOpen="False" AllowsTransparency="True" PopupAnimation="Slide" VerticalOffset="5">
                                <Border Background="#1A1A1A" BorderBrush="{StaticResource AccentColor}" BorderThickness="1" CornerRadius="6" Width="250" MaxHeight="300">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" BlurRadius="15" ShadowDepth="5" Opacity="0.8"/>
                                    </Border.Effect>
                                    <ListBox x:Name="LstSearchResults" Background="Transparent" BorderThickness="0" 
                                             Foreground="White" SelectionChanged="LstSearchResults_SelectionChanged">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Padding" Value="10,8"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ListBoxItem">
                                                            <Border x:Name="bdr" Background="Transparent" CornerRadius="4">
                                                                <ContentPresenter/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="bdr" Property="Background" Value="#33FFD700"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="13" Foreground="{StaticResource AccentColor}"/>
                                                    <TextBlock Text="{Binding Description}" FontSize="10" Foreground="#AAA" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </Popup>
                        </Grid>
                    </StackPanel>

                    <!-- ITENS DE MENU -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                        <StackPanel>
                            <RadioButton x:Name="BtnDashboard" GroupName="Menu" Tag="🏠" Content="Sistema (Início)" IsChecked="True" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click"/>
                            <RadioButton x:Name="BtnTweaks"    GroupName="Menu" Tag="⚡" Content="Desempenho" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click"/>
                            <RadioButton x:Name="BtnScreen"    GroupName="Menu" Tag="🖥️" Content="Tela e Cores" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click"/>
                            <RadioButton x:Name="BtnApps"      GroupName="Menu" Tag="📱" Content="Aplicativos (Bloat)" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click"/>
                            <RadioButton x:Name="BtnIntegrity"  GroupName="Menu" Tag="🔐" Content="Segurança e Privacidade" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click"
                             ToolTip="Configurações de Segurança e Privacidade"/>
                            <RadioButton x:Name="BtnStorage"   GroupName="Menu" Tag="💿" Content="Armazenamento" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click"/>
                            <RadioButton x:Name="BtnPartitions" GroupName="Menu" Tag="💽" Content="Gerenciar Discos" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click"/>
                            <RadioButton x:Name="BtnNetwork"   GroupName="Menu" Tag="🌐" Content="Rede e Internet" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click"/>
                            <RadioButton x:Name="BtnGames"     GroupName="Menu" Tag="🎮" Content="Jogos" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click"/>
                            <RadioButton x:Name="BtnDrivers"   GroupName="Menu" Tag="💾" Content="Drivers" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click"/>
                            <RadioButton x:Name="BtnRepairs"   GroupName="Menu" Tag="🔧" Content="Reparos AIO" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click"/>
                            <RadioButton x:Name="BtnServices"  GroupName="Menu" Tag="🛡️" Content="Serviços" Style="{StaticResource NavButtonStyle}" Click="NavButton_Click"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- RODAPÉ DO MENU (SOBRE + MONITOR) -->
                    <StackPanel Grid.Row="2">
                        <Separator Background="{StaticResource CardBorder}" Margin="0,10" Opacity="0.5"/>
                        <RadioButton x:Name="BtnTray" GroupName="Menu" Tag="🔔" Content="📡 Monitor RAM (Tray)" 
                                     Style="{StaticResource NavButtonStyle}" 
                                     Foreground="{StaticResource TextMuted}"
                                     Click="NavButton_Click"
                                     ToolTip="Configurações do ícone na bandeja e monitor de RAM"/>
                        <!-- BOTÃO "SOBRE O PROJETO" ATUALIZADO COM O CLICK -->
                        <RadioButton GroupName="Menu" Tag="⚙️" Content="Sobre o Projeto" 
                                     Style="{StaticResource NavButtonStyle}" 
                                     Foreground="{StaticResource TextMuted}"
                                     Click="NavButton_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ========================================================= -->
            <!-- CONTEÚDO PRINCIPAL (DIREITA) -->
            <!-- ========================================================= -->
            <Frame x:Name="MainFrame" Grid.Row="0" Grid.Column="1" NavigationUIVisibility="Hidden" Background="Transparent" Margin="0,32,0,0" Panel.ZIndex="1"/>

            <!-- TOASTS (Notificações Flutuantes) -->
            <StackPanel x:Name="ToastContainer" 
                        Grid.Row="0" Grid.Column="1"
                        VerticalAlignment="Top" 
                        HorizontalAlignment="Right"
                        Margin="0,40,20,0"
                        Panel.ZIndex="9998"
                        Background="{x:Null}"/>

            <!-- ========================================================= -->
            <!-- PAINÉIS FLUTUANTES (Sobreposições) -->
            <!-- ========================================================= -->

            <!-- Central de Notificações (Sino) -->
            <controls:NotificationCenter x:Name="NotifPanel" Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Grid.ColumnSpan="2" 
                                         Panel.ZIndex="20000" Visibility="Collapsed"/>

            <!-- Modal Overlay (Diálogos) -->
            <Grid x:Name="OverlayContainer" Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Grid.ColumnSpan="2" 
                  Panel.ZIndex="10000" Visibility="Collapsed" Background="#CC000000">
                <Border x:Name="OverlayConfirm" Background="{StaticResource CardBackground}" BorderBrush="{StaticResource AccentColor}" 
                        BorderThickness="1" CornerRadius="15" Width="450" VerticalAlignment="Center" HorizontalAlignment="Center" 
                        Padding="30" Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock Text="CONFIRMAÇÃO" FontSize="20" FontWeight="Bold" Foreground="{StaticResource AccentColor}" Margin="0,0,0,15" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TxtConfirmMessage" Text="Deseja continuar?" Foreground="White" FontSize="14" Margin="0,0,0,30" TextAlignment="Center" TextWrapping="Wrap"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="NÃO" Click="BtnConfirmNo_Click" Style="{StaticResource SecondaryButtonStyle}" Width="120" Height="40" Margin="0,0,15,0"/>
                            <Button Content="SIM" Click="BtnConfirmYes_Click" Style="{StaticResource GoldButtonStyle}" Width="120" Height="40" FontWeight="Bold"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ========================================================= -->
            <!-- LOADING OVERLAY -->
            <!-- ========================================================= -->
            <controls:LoadingOverlay x:Name="LoadingOverlay" Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Grid.ColumnSpan="2" 
                                   Visibility="Collapsed" Panel.ZIndex="99999"/>

            <!-- ========================================================= -->
            <!-- CONSOLE GLOBAL (Terminal no Rodapé) -->
            <!-- ========================================================= -->
            <!-- Fica na Row 1, ocupa toda a largura (ColumnSpan 2), Altura definida no controle (200) -->
            <controls:GlobalConsole x:Name="GlobalConsolePanel" 
                                    Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                    Visibility="Collapsed" 
                                    Height="180" 
                                    Panel.ZIndex="15000"/>

            <!-- ========================================================= -->
            <!-- TERMINAL INTERATIVO (LEGACY MODE) -->
            <!-- ========================================================= -->
            <controls:InteractiveTerminal x:Name="LegacyTerminalPanel"
                                          Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Grid.ColumnSpan="2"
                                          Visibility="Collapsed"
                                          Panel.ZIndex="30000"
                                          Width="950" Height="650"
                                          HorizontalAlignment="Center" VerticalAlignment="Center">
                <controls:InteractiveTerminal.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="50" ShadowDepth="10" Opacity="0.8"/>
                </controls:InteractiveTerminal.Effect>
            </controls:InteractiveTerminal>

        </Grid>
    </Border>
</Window>