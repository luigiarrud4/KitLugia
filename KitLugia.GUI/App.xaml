<Application x:Class="KitLugia.GUI.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- === PALETA "LUXURY GOLD" === -->

        <!-- Fundo Gradiente Dourado (Preto com brilho dourado no topo esquerdo) -->
        <LinearGradientBrush x:Key="WindowBackground" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1A1505" Offset="0.0"/>
            <GradientStop Color="#0A0A0A" Offset="0.3"/>
            <GradientStop Color="#050505" Offset="1.0"/>
        </LinearGradientBrush>

        <!-- Cor de Destaque: Ouro -->
        <SolidColorBrush x:Key="AccentColor" Color="#FFD700"/>

        <!-- Transparências "Vidro" -->
        <SolidColorBrush x:Key="SidebarBackground" Color="#E6121212"/>
        <!-- 90% Preto -->
        <SolidColorBrush x:Key="CardBackground" Color="#15FFFFFF"/>
        <!-- Vidro fraco -->
        <SolidColorBrush x:Key="CardHover" Color="#25FFFFFF"/>
        <!-- Vidro médio -->
        <SolidColorBrush x:Key="CardBorder" Color="#33FFD700"/>
        <!-- Borda Dourada fraca -->
        <SolidColorBrush x:Key="NotificationSuccessBrush" Color="#4CAF50"/>
        <!-- Verde Sucesso -->
        <SolidColorBrush x:Key="NotificationErrorBrush" Color="#C42B1C"/>
        <!-- Textos -->
        <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#E0E0E0"/>
        <SolidColorBrush x:Key="TextMuted" Color="#858585"/>
        <SolidColorBrush x:Key="TextGold" Color="#FFD700"/>

        <!-- ESTILOS GERAIS DE FONTE -->
        <Style TargetType="Window">
            <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI, Arial"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Background" Value="{StaticResource WindowBackground}"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>

        <Style TargetType="Page">
            <Setter Property="FontFamily" Value="Segoe UI Variable Display, Segoe UI, Arial"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>

        <!-- === SCROLLBAR CUSTOMIZADA (Dourada e Fina) === -->
        <Style x:Key="ScrollBarThumb" TargetType="{x:Type Thumb}">
            <Setter Property="OverridesDefaultStyle" Value="true"/>
            <Setter Property="IsTabStop" Value="false"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Rectangle x:Name="rectangle" Fill="#444" Height="{TemplateBinding Height}" SnapsToDevicePixels="True" Width="{TemplateBinding Width}" RadiusX="3" RadiusY="3"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="true">
                                <Setter TargetName="rectangle" Property="Fill" Value="{StaticResource AccentColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Stylus.IsPressAndHoldEnabled" Value="false"/>
            <Setter Property="Stylus.IsFlicksEnabled" Value="false"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Width" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid x:Name="Bg" SnapsToDevicePixels="true">
                            <Track x:Name="PART_Track" IsDirectionReversed="true" IsEnabled="{TemplateBinding IsEnabled}">
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource ScrollBarThumb}"/>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ESTILO DO BOTÃO DE MENU (RADIOBUTTON PARA SELEÇÃO ÚNICA) -->
        <Style x:Key="NavButtonStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="5,2"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="6" Padding="12,0" BorderThickness="1" BorderBrush="Transparent">
                            <Grid>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock x:Name="icon" Text="{TemplateBinding Tag}" Width="30" FontSize="16" 
                                               VerticalAlignment="Center" FontFamily="Segoe UI Emoji"
                                               Foreground="{StaticResource TextSecondary}"/>
                                    <ContentPresenter VerticalAlignment="Center"/>
                                </StackPanel>
                                <!-- Indicador Dourado na esquerda quando selecionado -->
                                <Rectangle x:Name="ActiveBar" HorizontalAlignment="Left" Width="3" Height="20" RadiusX="1.5" RadiusY="1.5"
                                           Fill="{StaticResource AccentColor}" Visibility="Collapsed" Margin="-12,0,0,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#15FFFFFF"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="icon" Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#25FFD700"/>
                                <!-- Fundo Ouro fraco -->
                                <Setter TargetName="border" Property="BorderBrush" Value="#44FFD700"/>
                                <Setter Property="Foreground" Value="{StaticResource AccentColor}"/>
                                <Setter TargetName="icon" Property="Foreground" Value="{StaticResource AccentColor}"/>
                                <Setter TargetName="ActiveBar" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ESTILO DOS CARTÕES DE CONTEÚDO (GLASS) -->
        <Style x:Key="SettingsCardStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource CardBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Height" Value="75"/>
            <Setter Property="Margin" Value="0,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="cardBorder" Background="{TemplateBinding Background}" 
                                BorderBrush="{StaticResource CardBorder}" BorderThickness="1" 
                                CornerRadius="8">
                            <Grid Margin="16,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="30"/>
                                </Grid.ColumnDefinitions>
                                <!-- Círculo do Ícone -->
                                <Border Grid.Column="0" Width="40" Height="40" CornerRadius="20" Background="#15000000" HorizontalAlignment="Left">
                                    <TextBlock Text="{TemplateBinding Tag}" 
                                               FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center"
                                               FontFamily="Segoe UI Emoji"/>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0">
                                    <TextBlock Text="{TemplateBinding Content}" FontSize="15" FontWeight="SemiBold"/>
                                    <TextBlock Text="{TemplateBinding ToolTip}" FontSize="12" Foreground="{StaticResource TextMuted}"/>
                                </StackPanel>
                                <TextBlock Grid.Column="2" Text="›" FontSize="24" VerticalAlignment="Center" 
                                           Foreground="{StaticResource TextGold}" HorizontalAlignment="Right" Margin="0,-4,0,0"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="cardBorder" Property="Background" Value="{StaticResource CardHover}"/>
                                <Setter TargetName="cardBorder" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="cardBorder" Property="Background" Value="{StaticResource AccentColor}"/>
                                <Setter Property="Foreground" Value="Black"/>
                                <!-- Texto preto para ler no fundo ouro -->
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ESTILO TOGGLE SWITCH DOURADO -->
        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="{TemplateBinding Content}" FontSize="15" Foreground="{StaticResource TextPrimary}"/>
                                <TextBlock Text="{TemplateBinding ToolTip}" FontSize="12" Foreground="{StaticResource TextMuted}" TextWrapping="Wrap" Margin="0,2,10,0"/>
                            </StackPanel>
                            <Border Grid.Column="1" x:Name="SwitchBorder" Width="44" Height="24" CornerRadius="12" 
                                    Background="#3E3E3E" BorderBrush="#505050" BorderThickness="1">
                                <Ellipse x:Name="SwitchKnob" Width="14" Height="14" Fill="#BBBBBB" 
                                         HorizontalAlignment="Left" Margin="4,0">
                                    <Ellipse.Effect>
                                        <DropShadowEffect ShadowDepth="1" BlurRadius="2" Opacity="0.3"/>
                                    </Ellipse.Effect>
                                </Ellipse>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchBorder" Property="Background" Value="{StaticResource AccentColor}"/>
                                <Setter TargetName="SwitchBorder" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                                <Setter TargetName="SwitchKnob" Property="Fill" Value="#101010"/>
                                <Setter TargetName="SwitchKnob" Property="HorizontalAlignment" Value="Right"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Application.Resources>
</Application>