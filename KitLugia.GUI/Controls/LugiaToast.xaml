<UserControl x:Class="KitLugia.GUI.Controls.LugiaToast"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:KitLugia.GUI.Controls"
             Width="350" Margin="0,0,0,8" 
             Cursor="Hand"
             Background="Transparent">
    <!-- Width Reduzido para ocupar menos espaço -->

    <UserControl.Resources>
        <!-- Animações -->
        <Storyboard x:Key="SlideInAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.3"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" From="40" To="0" Duration="0:0:0.4">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>

        <Storyboard x:Key="SlideOutAnimation">
            <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.3"/>
            <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.X)" To="40" Duration="0:0:0.3">
                <DoubleAnimation.EasingFunction>
                    <CubicEase EasingMode="EaseIn"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard Storyboard="{StaticResource SlideInAnimation}"/>
        </EventTrigger>
    </UserControl.Triggers>

    <Border Name="ToastBorder" CornerRadius="6" BorderThickness="1" ClipToBounds="True">
        <Border.RenderTransform>
            <TranslateTransform X="0"/>
        </Border.RenderTransform>

        <Border.Style>
            <Style TargetType="Border">
                <!-- Estado Padrão (INFO / AGUARDE) -->
                <!-- Cores alteradas para #99... (Mais transparente) -->
                <Setter Property="BorderBrush" Value="#66FFD700"/>
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#992A2010" Offset="0"/>
                            <GradientStop Color="#CC0A0A0A" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect Color="#FFD700" BlurRadius="10" ShadowDepth="2" Opacity="0.2"/>
                    </Setter.Value>
                </Setter>

                <Style.Triggers>
                    <!-- SUCESSO -->
                    <DataTrigger Binding="{Binding ToastType}" Value="Success">
                        <Setter Property="BorderBrush" Value="#664CAF50"/>
                        <Setter Property="Background">
                            <Setter.Value>
                                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                    <GradientStop Color="#991B3320" Offset="0"/>
                                    <GradientStop Color="#CC0A0A0A" Offset="1"/>
                                </LinearGradientBrush>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect Color="#4CAF50" BlurRadius="10" ShadowDepth="2" Opacity="0.3"/>
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>

                    <!-- ERRO -->
                    <DataTrigger Binding="{Binding ToastType}" Value="Error">
                        <Setter Property="BorderBrush" Value="#66C42B1C"/>
                        <Setter Property="Background">
                            <Setter.Value>
                                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                                    <GradientStop Color="#993E1010" Offset="0"/>
                                    <GradientStop Color="#CC0A0A0A" Offset="1"/>
                                </LinearGradientBrush>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Effect">
                            <Setter.Value>
                                <DropShadowEffect Color="#C42B1C" BlurRadius="10" ShadowDepth="2" Opacity="0.4"/>
                            </Setter.Value>
                        </Setter>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Border.Style>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <!-- Coluna do Contador -->
            </Grid.ColumnDefinitions>

            <!-- Barra Lateral -->
            <Rectangle Grid.Column="0">
                <Rectangle.Style>
                    <Style TargetType="Rectangle">
                        <Setter Property="Fill" Value="{StaticResource AccentColor}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ToastType}" Value="Success">
                                <Setter Property="Fill" Value="{StaticResource NotificationSuccessBrush}"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ToastType}" Value="Error">
                                <Setter Property="Fill" Value="{StaticResource NotificationErrorBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Rectangle.Style>
            </Rectangle>

            <!-- Ícone -->
            <TextBlock Grid.Column="1" FontSize="18" Margin="10,0,10,0" VerticalAlignment="Center" FontFamily="Segoe UI Emoji">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Text" Value="⏳"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ToastType}" Value="Success">
                                <Setter Property="Text" Value="✅"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ToastType}" Value="Error">
                                <Setter Property="Text" Value="⚠️"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Textos -->
            <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,10,5,10">
                <TextBlock x:Name="TxtTitle" Text="TÍTULO" FontWeight="Bold" FontSize="12" Margin="0,0,0,2">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource AccentColor}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ToastType}" Value="Success">
                                    <Setter Property="Foreground" Value="{StaticResource NotificationSuccessBrush}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ToastType}" Value="Error">
                                    <Setter Property="Foreground" Value="{StaticResource NotificationErrorBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock x:Name="TxtMessage" Text="Mensagem aqui..." TextWrapping="Wrap" 
                           Foreground="#DDDDDD" FontSize="11" LineHeight="14"/>
            </StackPanel>

            <!-- CONTADOR DE DUPLICATAS (x2, x3...) -->
            <Border x:Name="BadgeCounter" Grid.Column="3" Background="#33FFFFFF" CornerRadius="10" 
                    Height="20" MinWidth="20" Margin="0,0,10,0" VerticalAlignment="Center"
                    Visibility="Collapsed">
                <!-- Começa invisível -->
                <TextBlock x:Name="TxtCount" Text="x1" Foreground="White" FontSize="10" FontWeight="Bold" 
                           HorizontalAlignment="Center" VerticalAlignment="Center" Padding="5,0"/>
            </Border>

        </Grid>
    </Border>
</UserControl>