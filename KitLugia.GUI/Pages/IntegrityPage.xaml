<Page x:Class="KitLugia.GUI.Pages.IntegrityPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      Title="Integridade do Sistema">

    <Page.Resources>
        <!-- Estilo do ToolTip (Balão de Informação) -->
        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#FFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MaxWidth" Value="400"/>
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 1. CABEÇALHO -->
        <Grid Grid.Row="0" Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Integridade &amp; Segurança" FontSize="32" FontWeight="SemiBold" Foreground="White"/>
                <TextBlock Text="Monitoramento ativo de vulnerabilidades e configurações críticas." Foreground="#AAA" Margin="0,5,0,0"/>
            </StackPanel>

            <Border Grid.Column="1" Width="90" Height="90" CornerRadius="45" BorderThickness="4" x:Name="BorderScore">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock x:Name="TxtScore" Text="100%" FontSize="26" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    <TextBlock Text="SCORE" FontSize="10" Foreground="#AAA" HorizontalAlignment="Center" FontWeight="Bold"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 2. BOTÕES GERAIS -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
            <Button x:Name="BtnFixAll" Content="🛡️ RESTAURAR TODOS (PADRÃO SEGURO)" Click="BtnFixAll_Click" 
                    Width="280" Height="40" Background="#C42B1C" Foreground="White" FontWeight="Bold" 
                    BorderThickness="0" Cursor="Hand" Visibility="Collapsed">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" Background="{TemplateBinding Background}" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="#FF5555"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bdr" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button Content="⟳ Re-escanear" Click="BtnRescan_Click" Margin="0,0,0,0" x:Name="BtnRescan"
                    Width="140" Height="40" Background="#222" Foreground="White" BorderBrush="#444" BorderThickness="1" Cursor="Hand">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="#333"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bdr" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </StackPanel>

        <!-- 3. LISTA DE ITENS -->
        <Border Grid.Row="2" Background="#111" BorderBrush="#333" BorderThickness="1" CornerRadius="8">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
                <ItemsControl x:Name="ItemsList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,0,0,1" Padding="15,10" Background="#161616" BorderBrush="#222" BorderThickness="0,0,0,1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40"/>
                                        <!-- Ícone Escudo -->
                                        <ColumnDefinition Width="*"/>
                                        <!-- Texto -->
                                        <ColumnDefinition Width="40"/>
                                        <!-- Ícone Info -->
                                        <ColumnDefinition Width="140"/>
                                        <!-- Status -->
                                        <ColumnDefinition Width="140"/>
                                        <!-- Botão -->
                                    </Grid.ColumnDefinitions>

                                    <!-- Escudo -->
                                    <TextBlock Text="🛡️" VerticalAlignment="Center" FontSize="18" Opacity="0.7"/>

                                    <!-- Nome e Categoria -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="5,0,10,0">
                                        <TextBlock Text="{Binding Name}" Foreground="White" FontWeight="SemiBold" FontSize="14" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Category}" Foreground="#666" FontSize="11"/>
                                    </StackPanel>

                                    <!-- BOTÃO DE INFORMAÇÃO (AGORA CLICÁVEL) -->
                                    <Button Grid.Column="2" Click="BtnInfo_Click" Tag="{Binding Description}"
                                            Background="Transparent" BorderThickness="0" 
                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Width="30" Height="30" Cursor="Help"
                                            ToolTipService.InitialShowDelay="0" ToolTipService.ShowDuration="20000">
                                        <Button.ToolTip>
                                            <ToolTip Content="{Binding Description}"/>
                                        </Button.ToolTip>
                                        <TextBlock Text="ℹ️" FontSize="16" Opacity="0.6"/>
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="Transparent">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Opacity" Value="1"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                    <!-- Badge de Status -->
                                    <Border Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,15,0"
                                            CornerRadius="4" Padding="10,4" MinWidth="100" x:Name="StatusBadge">
                                        <TextBlock x:Name="TxtStatus" FontSize="11" FontWeight="Bold" HorizontalAlignment="Center"/>
                                    </Border>

                                    <!-- Botão de Ação -->
                                    <Button Grid.Column="4" Click="BtnToggleItem_Click" Tag="{Binding}"
                                            Height="32" Width="120" Cursor="Hand" HorizontalAlignment="Right"
                                            x:Name="BtnAction" FontWeight="SemiBold" FontSize="11">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="bdr" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="4">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="bdr" Property="Opacity" Value="0.8"/>
                                                    </Trigger>
                                                    <Trigger Property="IsEnabled" Value="False">
                                                        <Setter TargetName="bdr" Property="Opacity" Value="0.5"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>

                                </Grid>
                            </Border>

                            <!-- TRIGGERS VISUAIS -->
                            <DataTemplate.Triggers>
                                <!-- ESTADO: MODIFICADO (Era RISCO) -->
                                <DataTrigger Binding="{Binding Status}" Value="MODIFIED">
                                    <!-- Fundo Vermelho Escuro -->
                                    <Setter TargetName="StatusBadge" Property="Background" Value="#25C42B1C"/>

                                    <!-- Texto alterado para MODIFICADO -->
                                    <Setter TargetName="TxtStatus" Property="Text" Value="MODIFICADO"/>
                                    <Setter TargetName="TxtStatus" Property="Foreground" Value="#FF6F61"/>

                                    <Setter TargetName="BtnAction" Property="Content" Value="CORRIGIR"/>
                                    <Setter TargetName="BtnAction" Property="Background" Value="{StaticResource AccentColor}"/>
                                    <Setter TargetName="BtnAction" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                                    <Setter TargetName="BtnAction" Property="Foreground" Value="Black"/>
                                </DataTrigger>

                                <!-- ESTADO: OK/SEGURO -->
                                <DataTrigger Binding="{Binding Status}" Value="OK">
                                    <Setter TargetName="StatusBadge" Property="Background" Value="#154CAF50"/>
                                    <Setter TargetName="TxtStatus" Property="Text" Value="PROTEGIDO"/>
                                    <Setter TargetName="TxtStatus" Property="Foreground" Value="#4CAF50"/>

                                    <Setter TargetName="BtnAction" Property="Content" Value="Desativar"/>
                                    <Setter TargetName="BtnAction" Property="Background" Value="Transparent"/>
                                    <Setter TargetName="BtnAction" Property="BorderBrush" Value="#333"/>
                                    <Setter TargetName="BtnAction" Property="Foreground" Value="#777"/>
                                </DataTrigger>

                                <!-- ESTADO: N/A -->
                                <DataTrigger Binding="{Binding Status}" Value="NOT_FOUND">
                                    <Setter TargetName="StatusBadge" Property="Background" Value="#111"/>
                                    <Setter TargetName="TxtStatus" Property="Text" Value="N/A"/>
                                    <Setter TargetName="TxtStatus" Property="Foreground" Value="#555"/>
                                    <Setter TargetName="BtnAction" Property="Visibility" Value="Hidden"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</Page>