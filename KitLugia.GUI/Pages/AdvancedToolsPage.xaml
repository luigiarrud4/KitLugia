<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="KitLugia.GUI.Pages.AdvancedToolsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Ferramentas Avançadas">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30" MaxWidth="1100">
            <!-- Header -->
            <StackPanel Margin="0,0,0,40" HorizontalAlignment="Center">
                <TextBlock Text="FERRAMENTAS AVANÇADAS" FontSize="36" FontWeight="Bold" 
                          Foreground="{StaticResource AccentColor}" HorizontalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#FFD700" BlurRadius="15" ShadowDepth="0" Opacity="0.5"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock Text="Winhance + Winboot: Suite Completa de Instalação e Customização" 
                          Foreground="{StaticResource TextMuted}" FontSize="16" HorizontalAlignment="Center" Margin="0,10,0,0"/>
            </StackPanel>

            <!-- Grid Principal -->
            <Grid Margin="0,0,0,40">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Módulo 1: ISO Editor (Winhance) -->
                <Border Grid.Column="0" Background="{StaticResource CardBackground}" BorderBrush="{StaticResource AccentColor}" BorderThickness="1" CornerRadius="12" Padding="25">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="💿" FontSize="28" VerticalAlignment="Center"/>
                            <TextBlock Text="WINHANCE" FontSize="22" FontWeight="Bold" 
                                      Foreground="{StaticResource AccentColor}" Margin="10,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="Editor de ISO Profissional" FontSize="16" FontWeight="SemiBold" 
                                  Foreground="{StaticResource TextPrimary}" Margin="0,0,0,10"/>
                        <TextBlock Text="Monte ISOs, injete drivers e crie imagens personalizadas." 
                                  Foreground="{StaticResource TextMuted}" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,20" Height="40"/>
                        
                        <TextBlock x:Name="TxtIsoPath" Text="📁 Nenhuma ISO selecionada" 
                                  Foreground="{StaticResource TextMuted}" FontStyle="Italic" FontSize="12" Margin="0,0,0,10" 
                                  TextTrimming="CharacterEllipsis"/>
                        
                        <Button x:Name="BtnSelectIso" Content="Selecionar ISO" 
                                Click="BtnSelectIso_Click" Style="{StaticResource GoldButtonStyle}"/>
                        
                        <StackPanel x:Name="PanelIsoActions" Visibility="Collapsed" Margin="0,15,0,0">
                            <Button x:Name="BtnMountIso" Content="Montar ISO (PowerShell)" 
                                    Click="BtnMountIso_Click" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,5"/>
                            <Button x:Name="BtnInjectDrivers" Content="Injetar Drivers" 
                                    Click="BtnInjectDrivers_Click" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,0,5"/>
                            <Button x:Name="BtnCreateIso" Content="Criar ISO Final" 
                                    Click="BtnCreateIso_Click" Style="{StaticResource GoldButtonStyle}" Margin="0,0,0,5"/>
                            <TextBlock x:Name="TxtMountStatus" Text="" Foreground="{StaticResource AccentColor}" FontWeight="Bold" 
                                      HorizontalAlignment="Center" FontSize="12" Margin="0,5,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Módulo 2: Gerenciador de Partições (Full Page) -->
                <Border Grid.Column="2" Background="{StaticResource CardBackground}" BorderBrush="#4FC3F7" BorderThickness="1" CornerRadius="12" Padding="25">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                            <TextBlock Text="💽" FontSize="28" VerticalAlignment="Center"/>
                            <TextBlock Text="PARTIÇÕES" FontSize="22" FontWeight="Bold" 
                                      Foreground="#4FC3F7" Margin="10,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="Gerenciador de Discos Avançado" FontSize="16" FontWeight="SemiBold" 
                                  Foreground="{StaticResource TextPrimary}" Margin="0,0,0,10"/>
                        <TextBlock Text="Gerencie seus discos e partições de forma visual e profissional, substituindo o gerenciador padrão do Windows." 
                                  Foreground="{StaticResource TextMuted}" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,20" Height="60"/>
                        
                        <Button x:Name="BtnOpenPartitions" Content="🚀 ABRIR GERENCIADOR" 
                                Click="BtnOpenPartitions_Click" Style="{StaticResource GoldButtonStyle}" 
                                Background="#4FC3F7" BorderBrush="#4FC3F7" Height="45"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- LINHA 2: WINBOOT (NO-USB) -->
            <Border Background="#1A0505" BorderBrush="#FF4444" BorderThickness="1" CornerRadius="12" Padding="25">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="🚀" FontSize="32" VerticalAlignment="Center"/>
                        <TextBlock Text="WINBOOT (NO-USB)" FontSize="26" FontWeight="Bold" 
                                  Foreground="#FF4444" Margin="15,0,0,0"/>
                        <TextBlock Text="Instalação Local" FontSize="20" FontWeight="SemiBold" 
                                  Foreground="#FFA500" Margin="10,6,0,0"/>
                    </StackPanel>
                    
                    <TextBlock Text="Crie uma partição de boot no disco atual para formatar o PC sem mídia externa (Pen Drive)." 
                              Foreground="{StaticResource TextSecondary}" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,10"/>
                    
                    <StackPanel Margin="0,0,0,15">
                        <TextBlock Text="✅ Instalação Independente de Mídia (Sem Pen Drive)" Foreground="#88FF88" FontSize="11" Margin="0,0,0,2"/>
                        <TextBlock Text="✅ Suporte a Bypass Automático de TPM 2.0 e Secure Boot" Foreground="#88FF88" FontSize="11" Margin="0,0,0,2"/>
                        <TextBlock Text="✅ Reconhecimento Inteligente de Discos Físicos" Foreground="#88FF88" FontSize="11" Margin="0,0,0,2"/>
                        <TextBlock Text="✅ Requer apenas 8GB de espaço não alocado" Foreground="#88FF88" FontSize="11"/>
                    </StackPanel>

                    
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Status -->
                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="STATUS DA ISO" Foreground="{StaticResource TextMuted}" FontSize="11" Margin="0,0,0,5" FontWeight="Bold"/>
                            <Border Background="#222" BorderBrush="#444" BorderThickness="1" CornerRadius="4" Padding="10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="TxtIsoStatus" Text="⚠️ Nenhuma ISO selecionada" Foreground="#FFA500" FontWeight="Bold" FontSize="13"/>
                                    <TextBlock x:Name="TxtDriveInfo" Text="" Foreground="{StaticResource TextSecondary}" FontSize="13" Margin="10,0,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        
                        <!-- Botão -->
                        <StackPanel Grid.Column="2">
                            <Button x:Name="BtnWinboot" Content="🔥 ABRIR WINBOOT GUI" 
                                    Click="BtnWinboot_Click" Style="{StaticResource GoldButtonStyle}" 
                                    Background="#FF4444" BorderBrush="#FF4444" Height="45"/>

                            <TextBlock Text="⚠️ REQUER BACKUP - ALTO RISCO" Foreground="#FF6666" FontSize="10" 
                                      HorizontalAlignment="Center" Margin="0,5,0,0" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
