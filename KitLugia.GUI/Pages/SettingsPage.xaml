<Page x:Class="KitLugia.GUI.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Configurações">
    
    <Page.Resources>
        <Style x:Key="SettingsCard" TargetType="Border">
            <Setter Property="Background" Value="#1a1a1a"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="20"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30">
            
            <!-- Header -->
            <TextBlock Text="⚙️ CONFIGURAÇÕES" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       Margin="0,0,0,20"
                       Foreground="{StaticResource AccentColor}"/>
            
            <!-- Seção: Inicialização -->
            <Border Style="{StaticResource SettingsCard}">
                <StackPanel>
                    <TextBlock Text="INICIALIZAÇÃO" 
                               FontSize="14" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource AccentColor}"
                               Margin="0,0,0,15"/>
                    
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Iniciar com Windows" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="Inicia o Kit Lugia automaticamente" FontSize="11" Foreground="#888888"/>
                        </StackPanel>
                        <CheckBox x:Name="ToggleStartup" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}"/>
                    </Grid>
                    
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Rodar em segundo plano" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="Minimiza ao clicar no X (mantém ativo)" FontSize="11" Foreground="#888888"/>
                        </StackPanel>
                        <CheckBox x:Name="ToggleCloseToTray" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}"/>
                    </Grid>
                    
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Minimizar para bandeja" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="Ao fechar, minimiza para ícone na bandeja" FontSize="11" Foreground="#888888"/>
                        </StackPanel>
                        <CheckBox x:Name="ToggleTray" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" IsChecked="True"/>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- Seção: Módulos do Kit -->
            <Border Style="{StaticResource SettingsCard}">
                <StackPanel>
                    <TextBlock Text="MÓDULOS DO KIT" 
                               FontSize="14" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource AccentColor}"
                               Margin="0,0,0,15"/>
                    
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Monitor de RAM" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="Monitoramento em tempo real e limpeza automática" FontSize="11" Foreground="#888888"/>
                        </StackPanel>
                        <CheckBox x:Name="ToggleRAMMonitor" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" IsChecked="True"/>
                    </Grid>
                    
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="GameBoost Pro" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="Otimização avançada para jogos" FontSize="11" Foreground="#888888"/>
                        </StackPanel>
                        <CheckBox x:Name="ToggleGameBoost" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" IsChecked="True"/>
                    </Grid>
                    
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Turbo Boot" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="Ignora delay de inicialização de apps" FontSize="11" Foreground="#888888"/>
                        </StackPanel>
                        <CheckBox x:Name="ToggleTurboBoot" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}"/>
                    </Grid>
                    
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Turbo Shutdown" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="Fecha apps antes de desligar" FontSize="11" Foreground="#888888"/>
                        </StackPanel>
                        <CheckBox x:Name="ToggleTurboShutdown" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}"/>
                    </Grid>
                    
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Standby Clean" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="Evita acúmulo de lixo no Windows" FontSize="11" Foreground="#888888"/>
                        </StackPanel>
                        <CheckBox x:Name="ToggleStandbyClean" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" IsChecked="True"/>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- Seção: Sistema -->
            <Border Style="{StaticResource SettingsCard}">
                <StackPanel>
                    <TextBlock Text="SISTEMA" 
                               FontSize="14" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource AccentColor}"
                               Margin="0,0,0,15"/>
                    
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Notificações" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="Mostrar notificações do sistema" FontSize="11" Foreground="#888888"/>
                        </StackPanel>
                        <CheckBox x:Name="ToggleNotifications" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}" IsChecked="True"/>
                    </Grid>
                    
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Log Detalhado" FontWeight="SemiBold" Foreground="White"/>
                            <TextBlock Text="Grava logs detalhados para debugging" FontSize="11" Foreground="#888888"/>
                        </StackPanel>
                        <CheckBox x:Name="ToggleVerboseLogging" Grid.Column="1" Style="{StaticResource ToggleSwitchStyle}"/>
                    </Grid>
                </StackPanel>
            </Border>
            
            <!-- Seção: Modo Desenvolvedor (DEBUG) -->
            <Border Style="{StaticResource SettingsCard}" BorderBrush="#FF6B00">
                <StackPanel>
                    <Grid Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="🐛 MODO DESENVOLVEDOR" 
                                       FontSize="14" 
                                       FontWeight="Bold" 
                                       Foreground="#FF6B00"/>
                            <TextBlock Text="Mostra ferramentas de diagnóstico e debug" FontSize="11" Foreground="#888888"/>
                        </StackPanel>
                        <CheckBox x:Name="ToggleDeveloperMode" 
                                  Grid.Column="1" 
                                  Style="{StaticResource ToggleSwitchStyle}"
                                  Checked="ToggleDeveloperMode_Checked"
                                  Unchecked="ToggleDeveloperMode_Unchecked"/>
                    </Grid>
                    
                    <TextBlock Text="Ferramentas visíveis quando ativado:" 
                               FontSize="11" 
                               Foreground="#888888"
                               Margin="0,0,0,10"/>
                    <StackPanel Margin="15,0">
                        <TextBlock Text="• Diagnóstico Interno (no menu lateral)" FontSize="11" Foreground="#CCCCCC"/>
                        <TextBlock Text="• Console de Logs (painel inferior)" FontSize="11" Foreground="#CCCCCC"/>
                        <TextBlock Text="• Memory Profiler (na página Diagnóstico)" FontSize="11" Foreground="#CCCCCC"/>
                        <TextBlock Text="• Stack traces detalhados de erros" FontSize="11" Foreground="#CCCCCC"/>
                    </StackPanel>
                </StackPanel>
            </Border>
            
        </StackPanel>
    </ScrollViewer>
</Page>
