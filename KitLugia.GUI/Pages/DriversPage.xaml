<Page x:Class="KitLugia.GUI.Pages.DriversPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      Title="Drivers" d:DesignHeight="750" d:DesignWidth="1000">

    <Page.Resources>
        <!-- Estilos Locais (Mantidos e Expandidos) -->
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="{StaticResource AccentColor}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentColor}"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                            </Border>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#05FFFFFF"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#DDD"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#15FFFFFF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#25FFD700"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" BorderThickness="0">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource AccentColor}"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#15FFFFFF"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#333"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="#25FFFFFF"/>
                                <Setter TargetName="bdr" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GoldButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentColor}"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ContentPresenter VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <Border Grid.Column="1" x:Name="SwitchBorder" Width="40" Height="20" CornerRadius="10" Background="#333" BorderBrush="#555" BorderThickness="1">
                                <Ellipse x:Name="SwitchKnob" Width="12" Height="12" Fill="#AAA" HorizontalAlignment="Left" Margin="3,0"/>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchBorder" Property="Background" Value="{StaticResource AccentColor}"/>
                                <Setter TargetName="SwitchBorder" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                                <Setter TargetName="SwitchKnob" Property="Fill" Value="#111"/>
                                <Setter TargetName="SwitchKnob" Property="HorizontalAlignment" Value="Right"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Tab Style -->
        <Style TargetType="TabItem">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border" Background="{TemplateBinding Background}" BorderBrush="Transparent" BorderThickness="0,0,0,3" Margin="0,0,10,0">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentColor}" />
                                <Setter Property="Foreground" Value="{StaticResource AccentColor}" />
                                <Setter Property="FontWeight" Value="Bold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <ContextMenu x:Key="DriverContextMenu" Background="#1A1A1A" BorderBrush="{StaticResource AccentColor}" BorderThickness="1" Foreground="White">
            <MenuItem Header="Desinstalar (Forçar Remoção)" Click="CtxUninstall_Click" Background="Transparent" Foreground="#FF6F61" FontWeight="Bold"/>
            <Separator Background="#333"/>
            <MenuItem Header="Copiar Nome" Click="CtxCopyName_Click" Background="Transparent" Foreground="White"/>
            <MenuItem Header="Copiar ID de Hardware" Click="CtxCopyId_Click" Background="Transparent" Foreground="White"/>
        </ContextMenu>
    </Page.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Central de Drivers" FontSize="32" FontWeight="SemiBold" Foreground="White"/>
            <TextBlock Text="Gerenciamento profissional, backup e diagnóstico de falhas." Foreground="#999" Margin="0,5,0,0"/>
        </StackPanel>

        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">

            <!-- ABA 1: LISTA DE DRIVERS (Original) -->
            <TabItem Header="Lista de Drivers">
                <Grid Margin="0,15,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Barra de Ferramentas -->
                    <Border Grid.Row="0" Background="#15FFFFFF" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="8" Padding="15" Margin="0,0,0,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="🛠️ Ferramentas" FontWeight="Bold" Foreground="{StaticResource AccentColor}" Margin="0,0,0,10"/>
                                <WrapPanel Orientation="Horizontal">
                                    <Button Content="📥 Instalar (CAB/ZIP)" Click="BtnInstallFromFolder_Click" Width="140" Height="30" Margin="0,0,10,10" Style="{StaticResource SecondaryButtonStyle}" ToolTip="Instala drivers de arquivos compactados ou pastas."/>
                                    <Button Content="💾 Backup Completo" Click="BtnBackup_Click" Width="130" Height="30" Margin="0,0,10,10" Style="{StaticResource SecondaryButtonStyle}"/>
                                    <Button Content="📄 Exportar TXT" Click="BtnExportList_Click" Width="110" Height="30" Margin="0,0,10,10" Style="{StaticResource SecondaryButtonStyle}"/>
                                </WrapPanel>
                            </StackPanel>

                            <Rectangle Grid.Column="1" Width="1" Fill="#333" Margin="15,5"/>

                            <StackPanel Grid.Column="2" Margin="15,0,0,0">
                                <TextBlock Text="🚀 Atualização Automática" FontWeight="Bold" Foreground="{StaticResource AccentColor}" Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Content="🔍 Procurar (Web/Auto)" Click="BtnAutoScan_Click" Height="35" Style="{StaticResource GoldButtonStyle}" ToolTip="Verifica drivers antigos e busca no Catálogo Microsoft."/>
                                    <Button Grid.Column="2" Content="☁️ Windows Update" Click="BtnWindowsUpdate_Click" Height="35" Style="{StaticResource SecondaryButtonStyle}"/>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Tabela e Filtros -->
                    <Grid Grid.Row="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Filtros -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Background="#111" CornerRadius="4" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" Height="35">
                                <Grid>
                                    <TextBlock Text="🔍 Filtrar lista..." VerticalAlignment="Center" Margin="10,0" Foreground="#555" IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=TxtFilter}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBox x:Name="TxtFilter" Background="Transparent" BorderThickness="0" Foreground="White" VerticalAlignment="Center" Margin="5,0" TextChanged="TxtFilter_TextChanged" CaretBrush="{StaticResource AccentColor}"/>
                                </Grid>
                            </Border>

                            <CheckBox x:Name="ChkShowMicrosoft" Grid.Column="1" Content="Mostrar Drivers Microsoft" 
                                      VerticalAlignment="Center" Foreground="#AAA" Margin="15,0,0,0" 
                                      Style="{StaticResource ToggleSwitchStyle}"
                                      Checked="ChkShowMicrosoft_Checked" Unchecked="ChkShowMicrosoft_Checked"/>
                        </Grid>

                        <!-- Tabela -->
                        <DataGrid x:Name="GridDrivers" Grid.Row="1" Background="#111" BorderBrush="#333" BorderThickness="1"
                                  AutoGenerateColumns="False" CanUserAddRows="False" HeadersVisibility="Column"
                                  RowBackground="Transparent" AlternatingRowBackground="#0AFFFFFF" Foreground="#DDD"
                                  GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#333" SelectionMode="Extended">

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                                    <Setter Property="ContextMenu" Value="{StaticResource DriverContextMenu}"/>
                                </Style>
                            </DataGrid.RowStyle>

                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Binding="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}" Width="40" ElementStyle="{StaticResource {x:Type CheckBox}}">
                                    <DataGridCheckBoxColumn.HeaderTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="☑" FontSize="16" Foreground="{StaticResource AccentColor}" ToolTip="Selecionar"/>
                                        </DataTemplate>
                                    </DataGridCheckBoxColumn.HeaderTemplate>
                                </DataGridCheckBoxColumn>

                                <DataGridTemplateColumn Width="40">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Icon}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Fabricante" Binding="{Binding Provider}" Width="140" FontWeight="Bold"/>
                                <DataGridTextColumn Header="Dispositivo" Binding="{Binding DeviceName}" Width="*"/>
                                <DataGridTextColumn Header="Versão" Binding="{Binding Version}" Width="120"/>
                                <DataGridTextColumn Header="Data" Binding="{Binding Date}" Width="100"/>

                                <DataGridTemplateColumn Header="Status" Width="140">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding UpdateStatus}" VerticalAlignment="Center" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding UpdateStatus}" Value="Atualizado">
                                                                <Setter Property="Foreground" Value="#4CAF50"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding UpdateStatus}" Value="Antigo">
                                                                <Setter Property="Foreground" Value="#FF6F61"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding UpdateStatus}" Value="Verificando...">
                                                                <Setter Property="Foreground" Value="{StaticResource AccentColor}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Rodapé -->
                        <Grid Grid.Row="2" Margin="0,10,0,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                <Button Content="⬇️ Baixar Selecionados" Click="BtnInstallSelected_Click" Style="{StaticResource SecondaryButtonStyle}" Height="30" Width="160" Foreground="{StaticResource AccentColor}" BorderBrush="{StaticResource AccentColor}" ToolTip="Abre o Catálogo Microsoft."/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock x:Name="TxtStatus" Text="Aguardando..." Foreground="#666" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                <TextBlock x:Name="TxtCount" Text="0 Drivers" Foreground="{StaticResource AccentColor}" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ABA 2: DIAGNÓSTICO (BSOD / VERIFIER) - NOVA! -->
            <TabItem Header="Diagnóstico (BSOD)">
                <Grid Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="350"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,30,0">
                        <TextBlock Text="Driver Verifier" FontSize="22" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>
                        <TextBlock Text="Ferramenta avançada para estressar drivers e identificar qual deles está causando Telas Azuis da Morte (BSOD)." Foreground="#CCC" TextWrapping="Wrap" Margin="0,0,0,20"/>

                        <Border Background="#20FF5555" BorderBrush="#FF5555" BorderThickness="1" CornerRadius="6" Padding="15" Margin="0,0,0,25">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="⚠️" FontSize="30" VerticalAlignment="Center" Margin="0,0,15,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="PERIGO: USO AVANÇADO" FontWeight="Bold" Foreground="#FF5555" FontSize="14"/>
                                    <TextBlock Text="Esta ferramenta força o Windows a travar (BSOD) se encontrar um erro." Foreground="#EEE" Margin="0,5,0,0"/>
                                    <TextBlock Text="Se o PC entrar em 'Boot Loop', entre em Modo de Segurança e use este menu para DESATIVAR." Foreground="#AAA" FontStyle="Italic" FontSize="11" Margin="0,5,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Grid>
                        </Border>

                        <TextBlock Text="Estado Atual:" Foreground="#888" Margin="0,0,0,5"/>
                        <Border Background="#1A1A1A" CornerRadius="4" Padding="10" HorizontalAlignment="Left">
                            <TextBlock x:Name="TxtVerifierStatus" Text="DESCONHECIDO" Foreground="White" FontWeight="Bold"/>
                        </Border>

                        <StackPanel Orientation="Horizontal" Margin="0,30,0,0">
                            <Button Content="ATIVAR (Estresse Padrão)" Click="BtnEnableVerifier_Click" Height="45" Width="200" Background="#C42B1C" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="0,0,15,0">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="bdr" Background="{TemplateBinding Background}" CornerRadius="6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="bdr" Property="Background" Value="#FF5555"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>

                            <Button Content="DESATIVAR / RESETAR" Click="BtnDisableVerifier_Click" Height="45" Width="180" Style="{StaticResource GoldButtonStyle}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Dicas Laterais -->
                    <Border Grid.Column="1" Background="#111" BorderBrush="#333" BorderThickness="1" CornerRadius="8" Padding="20" VerticalAlignment="Top">
                        <StackPanel>
                            <TextBlock Text="Instruções de Uso" FontWeight="Bold" Foreground="{StaticResource AccentColor}" FontSize="14" Margin="0,0,0,15"/>

                            <TextBlock Text="1. Ative o Verifier." Foreground="White" Margin="0,0,0,5"/>
                            <TextBlock Text="O Windows pedirá reinicialização." Foreground="#777" FontSize="11" Margin="0,0,0,15"/>

                            <TextBlock Text="2. Use o PC normalmente." Foreground="White" Margin="0,0,0,5"/>
                            <TextBlock Text="Jogue ou execute tarefas pesadas até a Tela Azul ocorrer." Foreground="#777" FontSize="11" Margin="0,0,0,15"/>

                            <TextBlock Text="3. Anote o erro." Foreground="White" Margin="0,0,0,5"/>
                            <TextBlock Text="Na tela azul, veja o nome do arquivo (ex: nvlddmkm.sys)." Foreground="#777" FontSize="11" Margin="0,0,0,15"/>

                            <TextBlock Text="4. Desative o Verifier." Foreground="White" Margin="0,0,0,5"/>
                            <TextBlock Text="Volte aqui e clique em RESETAR para voltar ao normal." Foreground="#777" FontSize="11"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- Loading Overlay -->
        <Grid x:Name="LoadingOverlay" Grid.Row="0" Grid.RowSpan="3" Background="#D9000000" Visibility="Collapsed" Panel.ZIndex="99">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="⚙️" FontSize="40" HorizontalAlignment="Center" Foreground="{StaticResource AccentColor}"/>
                <TextBlock x:Name="TxtLoadingMsg" Text="Processando..." Foreground="White" Margin="0,10,0,0" FontSize="16"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>