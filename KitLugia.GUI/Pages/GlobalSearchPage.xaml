<Page x:Class="KitLugia.GUI.Pages.GlobalSearchPage"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
mc:Ignorable="d"
Title="Resultados da Busca">
  
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- CABEÇALHO (Aqui está o TxtQueryDisplay) -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Resultados da Pesquisa" FontSize="28" FontWeight="SemiBold" Foreground="White"/>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Encontrados: " Foreground="#888" Margin="0,5,5,0"/>
                <TextBlock x:Name="TxtResultCount" Text="0 itens" Foreground="{StaticResource AccentColor}" FontWeight="Bold" Margin="0,5,20,0"/>

                <!-- Adicionado o TxtQueryDisplay de volta para evitar o erro CS0103, mesmo que esteja invisível se preferir -->
                <TextBlock x:Name="TxtQueryDisplay" Visibility="Collapsed"/>
            </StackPanel>
        </StackPanel>

        <!-- LISTA DE RESULTADOS -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ListResults">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- O CARD -->
                        <Border Background="{StaticResource CardBackground}" 
                            BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="8"
                            Width="340" Height="110" Margin="0,0,15,15" Padding="15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- Ícone -->
                                <Border Background="#15FFD700" CornerRadius="8" Width="40" Height="40" 
                                    VerticalAlignment="Top" HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding Icon}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" FontFamily="Segoe UI Emoji"/>
                                </Border>

                                <!-- Textos -->
                                <StackPanel Grid.Column="1" VerticalAlignment="Top" Margin="10,0,5,0">
                                    <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="Bold" FontSize="14" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Description}" Foreground="#999" FontSize="11" 
                                           TextWrapping="Wrap" MaxHeight="32" TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                                </StackPanel>

                                <!-- ÁREA DE AÇÃO -->
                                <Grid Grid.Column="2" VerticalAlignment="Center">

                                    <!-- OPÇÃO 1: BOTÃO NORMAL -->
                                    <Button Content="{Binding ButtonText}" Tag="{Binding}" Click="BtnExecute_Click"
                                        Height="30" FontSize="11" FontWeight="Bold" Padding="10,0" Cursor="Hand">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsToggle}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <!-- OPÇÃO 2: TOGGLE SWITCH (CORRIGIDO) -->
                                    <!-- Removido o atributo Style="{...}" duplicado. Agora está tudo dentro do <CheckBox.Style> -->
                                    <CheckBox IsChecked="{Binding IsActive, Mode=OneWay}"
                                          Tag="{Binding}" Click="BtnExecute_Click" Cursor="Hand">
                                        <CheckBox.Style>
                                            <Style TargetType="CheckBox" BasedOn="{StaticResource ToggleSwitchStyle}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsToggle}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </CheckBox.Style>
                                    </CheckBox>

                                </Grid>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- MENSAGEM DE VAZIO -->
        <StackPanel x:Name="PanelNoResults" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Visibility="Collapsed">
            <TextBlock Text="🔍" FontSize="50" HorizontalAlignment="Center" Opacity="0.3" Foreground="White"/>
            <TextBlock Text="Nenhum resultado." Foreground="#AAA" FontSize="16" Margin="0,15,0,0" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</Page>
