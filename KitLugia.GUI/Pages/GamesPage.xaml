<Page x:Class="KitLugia.GUI.Pages.GamesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Jogos">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30,30,30,50" MaxWidth="900">

            <TextBlock Text="Central de Jogos" FontSize="32" FontWeight="SemiBold" Margin="0,0,0,10" Foreground="White"/>
            <TextBlock Text="Ferramentas para aumentar FPS e estabilidade." Foreground="#A0A0A0" Margin="0,0,0,30"/>

            <!-- CARD PRINCIPAL: RAM BOOSTER -->
            <Border Background="{StaticResource CardBackground}" BorderBrush="{StaticResource AccentColor}" BorderThickness="1" CornerRadius="12" Padding="25" Margin="0,0,0,25">
                <Border.Effect>
                    <DropShadowEffect Color="#FFD700" BlurRadius="20" ShadowDepth="0" Opacity="0.1"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="⚡ RAM Booster (Otimizador)" FontSize="20" FontWeight="Bold" Foreground="White" Margin="0,0,0,5"/>
                        <TextBlock Text="Limpa processos em segundo plano e 'standby list' para liberar memória imediata para seu jogo." 
                                   Foreground="#CCCCCC" TextWrapping="Wrap" Margin="0,0,20,0"/>

                        <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                            <TextBlock Text="Memória Total: " Foreground="#888"/>
                            <TextBlock x:Name="TxtTotalRam" Text="Calculando..." Foreground="White" FontWeight="Bold"/>
                        </StackPanel>
                    </StackPanel>

                    <Button Grid.Column="1" Width="140" Height="45" Content="OTIMIZAR AGORA" 
                            Background="{StaticResource AccentColor}" Foreground="Black" FontWeight="ExtraBold"
                            FontSize="12" Cursor="Hand" Click="BtnBoostRam_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bdr" CornerRadius="22" Background="{TemplateBinding Background}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bdr" Property="Background" Value="White"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>
            </Border>

            <!-- TWEAKS DE JOGO -->
            <TextBlock Text="Ajustes do Windows (Registry)" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Coluna 1 -->
                <StackPanel Grid.Column="0">
                    <Border Background="#222" CornerRadius="8" Padding="15" Margin="0,0,0,10" BorderBrush="#333" BorderThickness="1">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Modo Jogo (Registro)" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="Define Prioridade GPU e Afinidade" FontSize="11" Foreground="#888"/>
                            </StackPanel>
                            <CheckBox x:Name="ChkGameMode" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right" Click="ChkGameMode_Click"/>
                        </Grid>
                    </Border>

                    <!-- Adicione mais botões aqui se necessário -->
                </StackPanel>

                <!-- Coluna 2 -->
                <StackPanel Grid.Column="2">
                    <Border Background="#222" CornerRadius="8" Padding="15" Margin="0,0,0,10" BorderBrush="#333" BorderThickness="1">
                        <Grid>
                            <StackPanel>
                                <TextBlock Text="Xbox Game Bar (DVR)" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="Gravação em 2º plano (Causa Input Lag)" FontSize="11" Foreground="#888"/>
                            </StackPanel>
                            <!-- Lógica invertida no Checkbox para facilitar UX: 'Marcado' = 'Desligado/Otimizado' -->
                            <CheckBox x:Name="ChkDvr" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right" Click="ChkDvr_Click" Content=""/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- EXTRA TOOLS -->
            <TextBlock Text="Extras" FontSize="16" FontWeight="Bold" Foreground="White" Margin="0,20,0,15"/>

            <Button Style="{StaticResource SettingsCardStyle}" Tag="🧹"
                    Content="Limpar Cache de Shaders (DirectX/GL)"
                    ToolTip="Corrige travamentos e recarrega texturas (NVIDIA/AMD)."
                    Click="BtnClearShaders_Click"/>

            <Button Style="{StaticResource SettingsCardStyle}" Tag="🔋"
                    Content="Plano de Energia: Alto Desempenho"
                    ToolTip="Ativa o plano padrão do Windows para jogos."
                    Click="BtnHighPerf_Click"/>

        </StackPanel>
    </ScrollViewer>
</Page>