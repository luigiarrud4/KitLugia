<Page x:Class="KitLugia.GUI.Pages.ServicesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      mc:Ignorable="d" 
      Title="ServicesPage" d:DesignHeight="700" d:DesignWidth="950">

    <Page.Resources>
        <!-- === ESTILOS COMPARTILHADOS === -->
        <Style TargetType="Button" x:Key="GoldButtonStyle">
            <Setter Property="Background" Value="{StaticResource AccentColor}"/>
            <Setter Property="Foreground" Value="Black"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" Background="{TemplateBinding Background}" CornerRadius="6" BorderThickness="1" BorderBrush="{StaticResource AccentColor}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="SecondaryButtonStyle">
            <Setter Property="Background" Value="{StaticResource CardBackground}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bdr" Background="{TemplateBinding Background}" CornerRadius="6" BorderThickness="1" BorderBrush="{StaticResource CardBorder}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bdr" Property="Background" Value="{StaticResource CardHover}"/>
                                <Setter TargetName="bdr" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ToolTip">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="MaxWidth" Value="450"/>
            <Setter Property="ContentTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" TextWrapping="Wrap"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Menu de Contexto -->
        <Style x:Key="ServiceContextMenu" TargetType="ContextMenu">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentColor}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="6" Padding="2">
                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="MenuItem" x:Key="ServiceMenuItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Border" Background="{TemplateBinding Background}" CornerRadius="4" Margin="2,1">
                            <ContentPresenter ContentSource="Header" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#33FFD700"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- DataGrid Styles -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#333"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="CanUserDeleteRows" Value="False"/>
            <Setter Property="CanUserResizeRows" Value="False"/>
            <Setter Property="CanUserSortColumns" Value="True"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="{StaticResource AccentColor}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0,0,0,2"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentColor}"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Grid>
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" Padding="10,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" VerticalAlignment="Center"/>
                                    <Path x:Name="SortArrow" Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Width="8" Height="6" Margin="5,0,0,0" Stretch="Fill" Fill="{StaticResource AccentColor}" RenderTransformOrigin="0.5,0.5" Visibility="Collapsed" Data="M0,0 L10,0 L5,10 z"/>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#252525"/>
                            </Trigger>
                            <Trigger Property="SortDirection" Value="Ascending">
                                <Setter TargetName="SortArrow" Property="Visibility" Value="Visible" />
                                <Setter TargetName="SortArrow" Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="180" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="SortDirection" Value="Descending">
                                <Setter TargetName="SortArrow" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="#05FFFFFF"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#15FFFFFF"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#25FFD700"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" BorderThickness="0">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource AccentColor}"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="TabItem">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextMuted}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Name="Border" Background="{TemplateBinding Background}" BorderBrush="Transparent" BorderThickness="0,0,0,3" Margin="0,0,10,0">
                            <ContentPresenter ContentSource="Header" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="BorderBrush" Value="{StaticResource AccentColor}" />
                                <Setter Property="Foreground" Value="{StaticResource AccentColor}" />
                                <Setter Property="FontWeight" Value="Bold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Gerenciador de Processos" Foreground="White" FontSize="32" FontWeight="SemiBold" Margin="0,0,0,20"/>

        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">

            <!-- ABA 1: STARTUP -->
            <TabItem Header="Inicialização (Startup)">
                <Grid Margin="0,15,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="Aplicativos que iniciam com o Windows" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                        <Button Content="Recarregar Lista" Click="BtnRefreshStartup_Click" Margin="20,0,0,0" Style="{StaticResource SecondaryButtonStyle}" Height="30" FontSize="12"/>
                    </StackPanel>

                    <Border Grid.Row="1" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="6" Background="#111">
                        <DataGrid x:Name="GridStartup" SelectionMode="Single">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Nome" Binding="{Binding Name}" Width="250" IsReadOnly="True" SortMemberPath="Name">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="Comando / Caminho" Binding="{Binding FullCommand}" Width="*" IsReadOnly="True" SortMemberPath="FullCommand">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                            <Setter Property="Foreground" Value="#777"/>
                                            <Setter Property="FontStyle" Value="Italic"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="ToolTip" Value="{Binding FullCommand}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTemplateColumn Header="Status" Width="140" IsReadOnly="True" SortMemberPath="Status">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock VerticalAlignment="Center" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="{Binding Status}"/>
                                                        <Setter Property="Foreground" Value="#777"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Enabled">
                                                                <Setter Property="Foreground" Value="#4CAF50"/>
                                                                <Setter Property="Text" Value="ATIVADO"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Disabled">
                                                                <Setter Property="Foreground" Value="#C42B1C"/>
                                                                <Setter Property="Text" Value="DESATIVADO"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Elevated">
                                                                <Setter Property="Foreground" Value="{StaticResource AccentColor}"/>
                                                                <Setter Property="Text" Value="ELEVADO (ADM)"/>
                                                                <Setter Property="Effect">
                                                                    <Setter.Value>
                                                                        <DropShadowEffect Color="#FFD700" BlurRadius="5" ShadowDepth="0" Opacity="0.4"/>
                                                                    </Setter.Value>
                                                                </Setter>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
                        <Button Content="Remover" Click="BtnRemoveStartup_Click" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,0" Foreground="#FF6F61"/>
                        <Button Content="Desabilitar / Habilitar Selecionado" Click="BtnToggleStartup_Click" Style="{StaticResource SecondaryButtonStyle}" Margin="0,0,10,0"/>

                        <Button x:Name="BtnAddStartup" Content="Adicionar Novo... ▾" Click="BtnAddStartup_Click" Style="{StaticResource GoldButtonStyle}">
                            <Button.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Adicionar Padrão (Sem Admin)" Click="MenuAddNormal_Click"/>
                                    <MenuItem Header="Adicionar como Administrador (Elevado)" Click="MenuAddAdmin_Click" Foreground="{StaticResource AccentColor}" FontWeight="Bold"/>
                                    <MenuItem Header="Adicionar com Atraso (2 min)" Click="MenuAddDelayed_Click"/>
                                    <MenuItem Header="Adicionar como Admin + Atraso (2 min)" Click="MenuAddAdminDelayed_Click" Foreground="{StaticResource AccentColor}"/>
                                </ContextMenu>
                            </Button.ContextMenu>
                        </Button>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ABA 2: OTIMIZAÇÃO DE SERVIÇOS -->
            <TabItem Header="Otimização de Serviços">
                <Grid Margin="0,15,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <!-- Cards -->
                        <RowDefinition Height="Auto"/>
                        <!-- Filtros -->
                        <RowDefinition Height="*"/>
                        <!-- Tabela -->
                        <RowDefinition Height="Auto"/>
                        <!-- Ações -->
                    </Grid.RowDefinitions>

                    <!-- PRESETS -->
                    <Grid Grid.Row="0" Margin="0,0,0,25">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Background="{StaticResource CardBackground}" CornerRadius="8" Padding="15" BorderThickness="1" BorderBrush="{StaticResource CardBorder}" MinHeight="140">
                            <StackPanel>
                                <TextBlock Text="🛡️ Otimização Segura" Foreground="White" FontWeight="Bold" FontSize="15" Margin="0,0,0,5"/>
                                <TextBlock Text="Desativa apenas serviços inúteis como Fax, RetailDemo e Spooler (se não usar impressora)." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" FontSize="12" Margin="0,0,0,15"/>
                                <Button Content="Aplicar Seguro" Click="BtnSafeOpt_Click" Style="{StaticResource SecondaryButtonStyle}" Height="30" VerticalAlignment="Bottom"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Background="{StaticResource CardBackground}" CornerRadius="8" Padding="15" BorderThickness="1" BorderBrush="{StaticResource AccentColor}" MinHeight="140">
                            <Border.Effect>
                                <DropShadowEffect Color="#FFD700" BlurRadius="10" Opacity="0.1" ShadowDepth="0"/>
                            </Border.Effect>
                            <StackPanel>
                                <TextBlock Text="🎮 Otimização Gamer" Foreground="{StaticResource AccentColor}" FontWeight="Bold" FontSize="15" Margin="0,0,0,5"/>
                                <TextBlock Text="Desativa Telemetria, SysMain, Mapas, Geo-loc e outros recursos que consomem RAM e CPU." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" FontSize="12" Margin="0,0,0,15"/>
                                <Button Content="Aplicar Gamer" Click="BtnGamerOpt_Click" Style="{StaticResource GoldButtonStyle}" Height="30" VerticalAlignment="Bottom"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="4" Background="{StaticResource CardBackground}" CornerRadius="8" Padding="15" BorderThickness="1" BorderBrush="{StaticResource CardBorder}" MinHeight="140">
                            <StackPanel>
                                <TextBlock Text="⏪ Restaurar" Foreground="White" FontWeight="Bold" FontSize="15" Margin="0,0,0,5"/>
                                <TextBlock Text="Reverte todos os serviços para o padrão de fábrica do Windows. Use se algo parar de funcionar." Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" FontSize="12" Margin="0,0,0,15"/>
                                <Button Content="Restaurar Tudo" Click="BtnRestoreServices_Click" Style="{StaticResource SecondaryButtonStyle}" Height="30" VerticalAlignment="Bottom"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- BARRA DE FERRAMENTAS -->
                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Busca e Contador -->
                        <StackPanel Orientation="Horizontal">
                            <Border Background="#20FFFFFF" CornerRadius="4" Height="30" Width="250" Margin="0,0,15,0">
                                <Grid>
                                    <TextBlock Text="🔍 Filtrar serviços..." Foreground="#888" VerticalAlignment="Center" Margin="10,0" IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Text, ElementName=TxtSearchService}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBox x:Name="TxtSearchService" Background="Transparent" BorderThickness="0" Foreground="White" VerticalAlignment="Center" Margin="5,0" TextChanged="TxtSearchService_TextChanged"/>
                                </Grid>
                            </Border>

                            <!-- Contador de Serviços -->
                            <TextBlock x:Name="TxtServiceCount" Text="Carregando..." Foreground="{StaticResource AccentColor}" VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"/>
                        </StackPanel>

                        <!-- Toggle Perigosos -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Mostrar Serviços Perigosos (Sistema)" Foreground="#AAA" VerticalAlignment="Center" Margin="0,0,10,0" FontSize="12"/>
                            <CheckBox x:Name="ChkShowDangerous" Style="{StaticResource ToggleSwitchStyle}" Click="ChkShowDangerous_Click"/>
                        </StackPanel>
                    </Grid>

                    <!-- TABELA DE SERVIÇOS -->
                    <Border Grid.Row="2" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="6" Background="#111">
                        <DataGrid x:Name="GridServices" SelectionMode="Single">
                            <DataGrid.Columns>
                                <!-- Nome Amigável -->
                                <DataGridTextColumn Header="Nome" Binding="{Binding DisplayName}" Width="220" IsReadOnly="True" SortMemberPath="DisplayName">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="ToolTip" Value="{Binding Description}"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- NOVA COLUNA: ID TÉCNICO -->
                                <DataGridTextColumn Header="ID (Técnico)" Binding="{Binding Name}" Width="150" IsReadOnly="True" SortMemberPath="Name">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Foreground" Value="#999"/>
                                            <Setter Property="FontStyle" Value="Italic"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- Status (Cor) -->
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="100" IsReadOnly="True" SortMemberPath="Status">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Style.Triggers>
                                                <Trigger Property="Text" Value="Executando">
                                                    <Setter Property="Foreground" Value="#4CAF50"/>
                                                </Trigger>
                                                <Trigger Property="Text" Value="Parado">
                                                    <Setter Property="Foreground" Value="#888"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <!-- Modo de Início -->
                                <DataGridTextColumn Header="Início" Binding="{Binding StartMode}" Width="100" IsReadOnly="True" SortMemberPath="StartMode"/>

                                <!-- Nível de Segurança (Badge Colorido) -->
                                <DataGridTemplateColumn Header="Segurança" Width="*" SortMemberPath="Safety">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="3" Padding="5,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Safety}" Value="Safe">
                                                                <Setter Property="Background" Value="#204CAF50"/>
                                                                <Setter Property="BorderBrush" Value="#4CAF50"/>
                                                                <Setter Property="BorderThickness" Value="1"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Safety}" Value="Dangerous">
                                                                <Setter Property="Background" Value="#20C42B1C"/>
                                                                <Setter Property="BorderBrush" Value="#C42B1C"/>
                                                                <Setter Property="BorderThickness" Value="1"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Safety}" Value="Caution">
                                                                <Setter Property="Background" Value="#20FFD700"/>
                                                                <Setter Property="BorderBrush" Value="#FFD700"/>
                                                                <Setter Property="BorderThickness" Value="1"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Safety}" Value="Unknown">
                                                                <Setter Property="Background" Value="#20FFD700"/>
                                                                <Setter Property="BorderBrush" Value="#FFD700"/>
                                                                <Setter Property="BorderThickness" Value="1"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Safety}" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>

                            <!-- Menu de Contexto (Botão Direito) -->
                            <DataGrid.ContextMenu>
                                <ContextMenu Style="{StaticResource ServiceContextMenu}">
                                    <MenuItem Header="Configurar: AUTOMÁTICO" Click="MenuSvcAuto_Click" Style="{StaticResource ServiceMenuItem}"/>
                                    <MenuItem Header="Configurar: MANUAL" Click="MenuSvcManual_Click" Style="{StaticResource ServiceMenuItem}"/>
                                    <MenuItem Header="Restaurar Padrão (Smart)" Click="MenuSvcDefault_Click" Style="{StaticResource ServiceMenuItem}" Foreground="{StaticResource AccentColor}"/>
                                    <Separator Background="#333"/>
                                    <MenuItem Header="Configurar: DESATIVADO" Click="MenuSvcDisabled_Click" Style="{StaticResource ServiceMenuItem}" Foreground="#FF6F61"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                        </DataGrid>
                    </Border>

                    <!-- Botão de Atualizar -->
                    <Button Grid.Row="3" Content="Recarregar Serviços" Click="BtnRefreshServices_Click" HorizontalAlignment="Right" Width="150" Margin="0,10,0,0" Style="{StaticResource SecondaryButtonStyle}"/>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Page>