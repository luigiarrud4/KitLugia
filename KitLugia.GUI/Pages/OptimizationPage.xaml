<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="KitLugia.GUI.Pages.OptimizationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Otimização Automática">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30" MaxWidth="950">
            <TextBlock Text="Automação de Sistema" FontSize="32" FontWeight="SemiBold" Foreground="{StaticResource TextPrimary}" Margin="0,0,0,10"/>
            <TextBlock Text="Defina regras para o KitLugia manter seu PC rápido automaticamente." Foreground="{StaticResource TextSecondary}" Margin="0,0,0,30"/>

            <!-- Card de Otimização -->
            <Border Background="{StaticResource CardBackground}" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="8" Padding="25" Margin="0,0,0,25">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="⚙️" FontSize="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Perfil de Otimização" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentColor}" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <TextBlock Text="Essas configurações serão aplicadas toda vez que o Windows iniciar." Foreground="{StaticResource TextMuted}" Margin="0,0,0,20"/>
                    
                    <Grid Margin="0,0,0,15">
                        <TextBlock Text="Forçar Modo de Alto Desempenho" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                        <CheckBox IsChecked="False" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>
                    </Grid>
                    
                    <Grid Margin="0,0,0,15">
                        <TextBlock Text="Limpar RAM ao atingir 90%" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                        <CheckBox IsChecked="True" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>
                    </Grid>
                    
                    <Grid Margin="0,0,0,15">
                        <TextBlock Text="Prioridade Alta para Jogos (Processo Ativo)" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                        <CheckBox IsChecked="True" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>
                    </Grid>
                    
                    <Grid>
                        <TextBlock Text="Desfragmentação Inteligente (Apenas HDD)" Foreground="{StaticResource TextPrimary}" VerticalAlignment="Center"/>
                        <CheckBox IsChecked="False" Style="{StaticResource ToggleSwitchStyle}" HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Card de Manutenção -->
            <Border Background="{StaticResource CardBackground}" BorderBrush="{StaticResource CardBorder}" BorderThickness="1" CornerRadius="8" Padding="25">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="🔧" FontSize="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Text="Tarefas de Manutenção" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentColor}" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <TextBlock Text="Executar ações manuais agora." Foreground="{StaticResource TextMuted}" Margin="0,0,0,20"/>
                    
                    <WrapPanel>
                        <Button Content="Limpar Arquivos Temporários" Style="{StaticResource SecondaryButtonStyle}" Width="200" Margin="0,0,10,10"/>
                        <Button Content="Otimizar Registro" Style="{StaticResource SecondaryButtonStyle}" Width="160" Margin="0,0,10,10"/>
                        <Button Content="Verificar Disco (CHKDSK)" Style="{StaticResource SecondaryButtonStyle}" Width="180" Margin="0,0,10,10"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
