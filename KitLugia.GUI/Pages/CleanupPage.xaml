<?xml version="1.0" encoding="utf-8"?>
<Page x:Class="KitLugia.GUI.Pages.CleanupPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Limpeza">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="30,30,30,50" MaxWidth="1000">

            <TextBlock Text="Limpeza de Sistema" FontSize="28" FontWeight="SemiBold" Margin="0,0,0,25" Foreground="White"/>

            <!-- PAINEL DE AÇÕES RÁPIDAS (3 Colunas) -->
            <Grid Margin="0,0,0,25">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="15"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- CARD 1: Arquivos Temporários -->
                <Button Grid.Column="0" Height="140" Click="BtnCleanTemp_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bdr" Background="#222" CornerRadius="8" BorderThickness="1" BorderBrush="#333" Padding="15">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="🗑️" FontSize="30" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                    <TextBlock Text="Arquivos Temporários" FontWeight="Bold" FontSize="14" Foreground="White" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Limpa %TEMP% e Windows/Temp" FontSize="11" Foreground="#999" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bdr" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                                    <Setter TargetName="bdr" Property="Background" Value="#2A2A2A"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- CARD 2: Windows Update -->
                <Button Grid.Column="2" Height="140" Click="BtnCleanUpdate_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bdr" Background="#222" CornerRadius="8" BorderThickness="1" BorderBrush="#333" Padding="15">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="📦" FontSize="30" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                    <TextBlock Text="Cache de Updates" FontWeight="Bold" FontSize="14" Foreground="White" HorizontalAlignment="Center"/>
                                    <TextBlock Text="SoftwareDistribution / Downloads" FontSize="11" Foreground="#999" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bdr" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                                    <Setter TargetName="bdr" Property="Background" Value="#2A2A2A"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- CARD 3: Shaders -->
                <Button Grid.Column="4" Height="140" Click="BtnCleanShaders_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bdr" Background="#222" CornerRadius="8" BorderThickness="1" BorderBrush="#333" Padding="15">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="🎮" FontSize="30" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                    <TextBlock Text="Cache de Shaders" FontWeight="Bold" FontSize="14" Foreground="White" HorizontalAlignment="Center"/>
                                    <TextBlock Text="NVIDIA &amp; AMD (DX/GL)" FontSize="11" Foreground="#999" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bdr" Property="BorderBrush" Value="{StaticResource AccentColor}"/>
                                    <Setter TargetName="bdr" Property="Background" Value="#2A2A2A"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- SEÇÃO INFERIOR: LOG + AÇÕES AVANÇADAS -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <!-- Log ocupa 2/3 -->
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="1*"/>
                    <!-- Botões avançados -->
                </Grid.ColumnDefinitions>

                <!-- CONSOLE DE LOG -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="LOG DE EXECUÇÃO" FontSize="12" Foreground="#777" Margin="0,0,0,5" FontWeight="Bold"/>

                    <Border Grid.Row="1" Background="#111" CornerRadius="6" BorderBrush="#333" BorderThickness="1" Height="250">
                        <ScrollViewer x:Name="LogScroller" VerticalScrollBarVisibility="Auto">
                            <TextBox x:Name="TxtLog" Background="Transparent" Foreground="#AAA" BorderThickness="0" 
                                     IsReadOnly="True" Padding="10" FontFamily="Consolas" TextWrapping="Wrap"
                                     Text="[Pronto] Aguardando comando..."/>
                        </ScrollViewer>
                    </Border>
                </Grid>

                <!-- BOTÕES LATERAIS (CompactOS, Etc) -->
                <StackPanel Grid.Column="2" Margin="0,20,0,0">
                    <TextBlock Text="Ferramentas Avançadas" FontSize="12" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>

                    <Button Content="LIMPEZA TOTAL (Todos)" Height="45" Background="{StaticResource AccentColor}" 
                            Foreground="Black" FontWeight="Bold" Margin="0,0,0,15"
                            Cursor="Hand" Click="BtnFullClean_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="CompactOS (Compressão)" Height="45" Background="#333" 
                            Foreground="White" BorderBrush="#555" BorderThickness="1"
                            Cursor="Hand" Click="BtnCompactOS_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bdr" Background="{TemplateBinding Background}" CornerRadius="4" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bdr" Property="Background" Value="#444"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                    <TextBlock Text="⚠️ CompactOS pode levar vários minutos e abrirá um CMD externo." 
                               FontSize="10" Foreground="#808080" TextWrapping="Wrap" Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</Page>